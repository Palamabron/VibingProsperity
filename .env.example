# Copy this file to `.env` and fill in values. `.env` is gitignored.
#
# Google AI Studio — required for `uv run autoresearch.py` (Gemini loop):
# ── Gemini (required for autoresearch_live.py) ────────────────────────────────
# GOOGLE_API_KEY=
#
# Optional Gemini model id (default: gemini-2.0-flash). Use a Pro model if your quota allows:
# Gemini model to use. Run `uv run python -c "from google import genai; client = genai.Client(api_key='YOUR_KEY'); [print(m.name) for m in client.models.list()]"` to list available models.
#GEMINI_MODEL=models/gemini-2.5-pro
#
# autoresearch_orchestrator.py (optional; defaults: gemini-2.5-pro + gemini-2.0-flash):
# GEMINI_MODEL_PRO=
# GEMINI_MODEL_FLASH=

# ── IMC Prosperity (required for live submission) ─────────────────────────────
# Cognito JWT token — valid for ~1 hour.
# To get a fresh token: uv run python scripts/get_token.py
# PROSPERITY_ID_TOKEN=
# Optional: automatic refresh when missing/expired (Playwright login) — set both:
# PROSPERITY_EMAIL=
# PROSPERITY_PASSWORD=
# Or run: uv run python scripts/get_token.py

# ── agent_cycle / autoresearch timeouts (seconds) ───────────────────────────
# AGENT_CYCLE_TIMEOUT_DATA_ANALYTICS=300
# AGENT_CYCLE_SCRIPT_TIMEOUT=7200
